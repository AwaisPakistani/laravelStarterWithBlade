🎯 Best Practices
1. Error Handling
php
public function handleCallback()
{
    try {
        $user = Socialite::driver('github')->user();
    } catch (\Laravel\Socialite\Two\InvalidStateException $e) {
        // Session state mismatch - restart flow
        return redirect('/auth/github/redirect');
    } catch (Exception $e) {
        // Log the error
        Log::error('Social login failed: ' . $e->getMessage());

        // Redirect with friendly message
        return redirect('/login')->with('error', 'Unable to login. Please try again.');
    }
}
2. User Linking
php
// Allow users to connect multiple social accounts
public function connectAccount(Request $request, $provider)
{
    $user = Auth::user();

    $socialUser = Socialite::driver($provider)->user();

    // Link the social account to current user
    $user->update([
        "{$provider}_id" => $socialUser->getId(),
        "{$provider}_token" => $socialUser->token,
    ]);

    return redirect()->back()->with('success', "{$provider} account connected!");
}
